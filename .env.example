# SIAP Automator - Variaveis de Ambiente
# Copie este arquivo para .env e preencha com seus dados

# Mercado Pago - Obtenha em https://www.mercadopago.com.br/developers
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxx

# Segredo para validar webhooks do Mercado Pago
WEBHOOK_SECRET=sua-chave-webhook-secreta

# Segredo para JWT (gere uma chave aleatoria forte)
JWT_SECRET=sua-chave-jwt-super-secreta-123

# URL base do site (mude para producao quando hospedar)
BASE_URL=http://localhost:4000

# WhatsApp para notificacoes (opcional)
WHATSAPP_NUMBER=5562999999999

# Porta do servidor
PORT=4000
